    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String foo = &quot;bar&quot;;&#xD;&#xA;int edad = 18;&#xD;&#xA;boolean estado = true;&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;***********VARIABLES LOCALES***********&quot;);&#xD;&#xA;&#xD;&#xA;edad=edad+5;&#xD;&#xA;foo=&quot;comida&quot;;&#xD;&#xA;estado=false;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;Variable foo = &quot;+foo);&#xD;&#xA;System.out.println(&quot;Variable edad = &quot;+edad);&#xD;&#xA;System.out.println(&quot;Variable estado = &quot;+estado);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;***********VARIABLES GLOBALES***********&quot;);&#xD;&#xA;&#xD;&#xA;globalMap.put(&quot;v_nombre&quot;, &quot;LUIS&quot;);&#xD;&#xA;globalMap.put(&quot;v_edad&quot;, 18);&#xD;&#xA;globalMap.put(&quot;v_estado&quot;, true);&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
