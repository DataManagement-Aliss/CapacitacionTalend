    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String foo = &quot;bar&quot;;&#xD;&#xA;int edad= 18;&#xD;&#xA;boolean estado =true;&#xD;&#xA;edad=edad+5;&#xD;&#xA;System.out.println(&quot;*****************Variables locales******************&quot;);&#xD;&#xA;System.out.println(&quot;Variable food=&quot;+&quot;: &quot;+foo);&#xD;&#xA;System.out.println(&quot;Variable edad=&quot;+&quot;: &quot; +edad);&#xD;&#xA;System.out.println(&quot;Variable estado=&quot;+&quot;: &quot;+estado);&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;*****************Variables globales******************&quot;);&#xD;&#xA;globalMap.put(&quot;V_Nombre&quot;,&quot;Alex&quot;);&#xD;&#xA;globalMap.put(&quot;V_Edad&quot;,18);&#xD;&#xA;globalMap.put(&quot;V_Estado&quot;,true);&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;Variable V_Nombre&quot;+&quot;: &quot;+ (String)globalMap.get(&quot;V_Nombre&quot;));&#xD;&#xA;System.out.println(&quot;Variable V_Edad&quot;+&quot;: &quot;+ (int)globalMap.get(&quot;V_Edad&quot;));&#xD;&#xA;System.out.println(&quot;Variable V_Estado&quot;+&quot;: &quot;+ (Boolean)globalMap.get(&quot;V_Estado&quot;));"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
