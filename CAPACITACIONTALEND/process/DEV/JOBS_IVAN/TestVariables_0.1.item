    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String foo = &quot;bar&quot;;&#xD;&#xA;int edad = 18;&#xD;&#xA;boolean estado = true;&#xD;&#xA;edad=18*2;&#xD;&#xA;foo=&quot;hola&quot;;&#xD;&#xA;System.out.println(&quot;****VARIABLES LOCALES****&quot;);&#xD;&#xA;System.out.println(&quot;variable foo:&quot;+foo);&#xD;&#xA;System.out.println(&quot;variable edad:&quot;+edad);&#xD;&#xA;System.out.println(&quot;variable estado:&quot;+estado);&#xD;&#xA;System.out.println(&quot;****VARIABLES GLOBALES****&quot;);&#xD;&#xA;globalMap.put(&quot;v_Nombre&quot;,&quot;Ivan&quot;);&#xD;&#xA;globalMap.put(&quot;v_Edad&quot;,18);&#xD;&#xA;globalMap.put(&quot;v_Estado&quot;,false);&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="520" posY="120">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_2" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="&#xD;&#xA;System.out.println(&quot;variable nombre:&quot;+ (String) globalMap.get(&quot;v_Nombre&quot;));&#xD;&#xA;System.out.println(&quot;variable edad:&quot;+ (Integer) globalMap.get(&quot;v_Edad&quot;));&#xD;&#xA;System.out.println(&quot;variable estado:&quot;+ (Boolean) globalMap.get(&quot;v_Estado&quot;));"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_2"/>
  </node>
